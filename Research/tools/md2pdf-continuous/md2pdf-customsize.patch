+// parseCustomPaperSize parses a "WxH" papersize string (in renderer units,
+// e.g. "595.28x60000") into width and height. Returns ok=false if the string
+// is not in that form, so callers fall back to named sizes (A4, Letter, ...).
+func parseCustomPaperSize(s string) (float64, float64, bool) {
+	parts := strings.SplitN(strings.ToLower(strings.TrimSpace(s)), "x", 2)
+	if len(parts) != 2 {
+		return 0, 0, false
+	}
+	w, err1 := strconv.ParseFloat(strings.TrimSpace(parts[0]), 64)
+	h, err2 := strconv.ParseFloat(strings.TrimSpace(parts[1]), 64)
+	if err1 != nil || err2 != nil || w <= 0 || h <= 0 {
+		return 0, 0, false
+	}
+	return w, h, true
+}
+
